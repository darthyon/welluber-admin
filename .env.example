# Supabase — copy to .env.local and fill in your values (never commit .env.local)
# Find these in: https://supabase.com/dashboard/project/_/settings/api
#
# NEXT_PUBLIC_* keys are intentionally exposed to the browser — Supabase anon key
# is a public project identifier, safe to ship in client bundles. Data is protected
# by Row Level Security (RLS) policies, not key secrecy.
#
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS entirely — keep it server-only, never
# prefix it with NEXT_PUBLIC_, never expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox public access token (client-safe, used for static map images)
# Get yours at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoi...
